# Copy to .env for local testing (do NOT commit real secrets).
# On Heroku set these as Config Vars instead.

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Notion ---
NOTION_TOKEN=ntn_...
# Orders database id (from its URL). This is the merenga "Orders" board:
NOTION_DATABASE_ID=dd219e070ba146a68599c6ee7a1a6649
NOTION_STATUS=New Order

# --- Gmail (App Password, no OAuth) ---
GMAIL_ADDRESS=your-bakery@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- App behavior ---
# SENDER_FILTER: pin to your order channel so marketing mail is never mistaken
# for an order. For live Squarespace orders use the line below.
# For manual testing from your own address, set it empty.
SENDER_FILTER=form-submission@squarespace.info
ORDER_KEYWORDS=cake,order,custom cake,inquiry,cupcake,dessert,birthday,wedding
BUSINESS_NAME=merenga cakes
REPLY_MODE=send          # send | off
DRY_RUN=true             # true = log only, nothing sent/written
MAX_PER_RUN=10           # 0 = no limit
